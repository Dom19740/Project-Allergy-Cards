<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    android:background="@drawable/widget_background">

    <!-- Header with Logo and Emergency Button (using TextView for better compatibility) -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/logo_main"
            android:contentDescription="App Logo" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btn_emergency"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="EMERGENCY"
            android:background="@drawable/emergency_button_bg"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Horizontal StackView for Cards -->
    <StackView
        android:id="@+id/card_stack"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_layout"
        android:layout_above="@+id/footer_text"
        android:animateFirstView="true"
        android:loopViews="true" />

    <!-- Empty View shown when no cards are saved -->
    <TextView
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_layout"
        android:layout_above="@+id/footer_text"
        android:gravity="center"
        android:text="No saved cards"
        android:textColor="#9CA3AF"
        android:visibility="gone" />

    <TextView
        android:id="@+id/footer_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:text="Simple Allergy Alert"
        android:textColor="#D1D5DB"
        android:textSize="10sp" />

</RelativeLayout>